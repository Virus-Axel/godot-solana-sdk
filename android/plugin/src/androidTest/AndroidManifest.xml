<?xml version="1.0" encoding="utf-8"?>
<!--
    Story 2-1 T9 — androidTest manifest overrides (D-T9-3 Rule 1).

    clientlib-ktx 2.0.3 declares uses-sdk:minSdkVersion=24 in its manifest.
    The main library manifest doesn't hit a merger error because AGP merges
    it once at AAR-build time and pins to 23 (the library minSdk overrides
    the transitive dep for production). For androidTest the manifest
    merger runs afresh and rejects the 23 < 24 combo.

    tools:overrideLibrary ships the androidTest-only acknowledgement that
    the clientlib may not be reachable on API 23 — fine because our
    instrumented tests run on API 33 emulator per DD-20.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-sdk
        android:minSdkVersion="24"
        tools:overrideLibrary="com.solana.mobilewalletadapter.clientlib" />

</manifest>
