// Fixture for Story 2-1 T5 — banned pattern #8 (log-payload-json).
// Story 4-3 T2 extended the pattern with `reauthDictJson` (postReauthRequired
// payload variable name); Story 3-3 T2 extended with `pendingDictJson`
// (postPendingSubmissionFound payload variable name) per DD-3-3-E.a.
// The .kt.bad extension prevents AGP from compiling this file; the grep
// script scans by glob, not by file type.
//
// Intentional violations on lines below — must NOT be fixed. This file
// exists so ci/grep_bans.sh --check-only proves pattern #8 fires.
// Pattern regex (excerpt):
//   (Log|SdkLog)\.(v|d|i|w|e).*(resultDictJson|errorDictJson|timeoutDictJson|cancelledDictJson|reauthDictJson|pendingDictJson)
// NativeBridge JSON payload parameters carry secret material (auth_token
// on the connect path; correlation metadata elsewhere; developer_details
// with exception class names on the reauth_required keystore_corrupt path;
// tx_preview_hashes that correlate transactions across observability channels
// on the pending_submission_found scan path) per Story 2-1 T5 kdoc + Story
// 4-3 DD-4-3-2 + Story 3-3 DD-3-3-E.a; logging or interpolating them is the
// leak surface this pattern guards.
package grep_ban_fixtures

import android.util.Log

fun badLogResultDictJson(resultDictJson: String) {
    Log.d("MWA", "postConnectCompletedNative payload=$resultDictJson")
}

fun badLogErrorDictJson(errorDictJson: String) {
    Log.i("MWA", "postMwaError payload=$errorDictJson")
}

fun badSdkLogTimeoutDictJson(timeoutDictJson: String) {
    // SdkLog.* receiver also covered by the pattern.
    @Suppress("unused")
    val _msg = "SdkLog.w reqId=xxx payload=$timeoutDictJson"
}

fun badLogCancelledDictJson(cancelledDictJson: String) {
    Log.w("MWA", "cancelledDictJson=$cancelledDictJson")
}

fun badLogReauthDictJson(reauthDictJson: String) {
    // Story 4-3 T2 — reauth_required payload variable name added to pattern-8
    // banned list. developer_details may carry exception class names; payload
    // logging is banned to keep the seam discipline uniform across all
    // *DictJson variables.
    Log.e("MWA", "postReauthRequired payload=$reauthDictJson")
}

fun badLogPendingDictJson(pendingDictJson: String) {
    // Story 3-3 T2 (DD-3-3-E.a) — pending_submission_found payload variable
    // name added to pattern-8 banned list. tx_preview_hashes are SHA-256
    // digests that, while not secret, can correlate transactions across
    // observability channels; payload logging is banned to keep the seam
    // discipline uniform across all *DictJson variables.
    Log.w("MWA", "postPendingSubmissionFound payload=$pendingDictJson")
}
